rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'createdAt', 'preferredLanguage', 'isAdmin']) &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256 &&
               data.displayName is string && data.displayName.size() <= 128 &&
               data.isAdmin == false;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'preferredLanguage']);
    }

    // Translations collection
    match /translations/{translationId} {
      function isValidTranslation(data) {
        return data.keys().hasAll(['userId', 'sourceText', 'translatedText', 'sourceLang', 'targetLang', 'type', 'createdAt']) &&
               data.userId == request.auth.uid &&
               data.sourceText is string && data.sourceText.size() <= 5000 &&
               data.translatedText is string && data.translatedText.size() <= 5000 &&
               data.sourceLang is string && data.sourceLang.size() <= 10 &&
               data.targetLang is string && data.targetLang.size() <= 10 &&
               data.type in ['text', 'voice', 'camera'] &&
               data.createdAt == request.time;
      }

      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTranslation(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
